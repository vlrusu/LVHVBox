# Generic service settings
I2C_SENSOR_SERVER_SENSOR_TYPE=bme680
I2C_SENSOR_SERVER_SENSOR_REPO=/home/mu2e/vr-dev/bme680-python
I2C_SENSOR_SERVER_HTTP_HOST=0.0.0.0
I2C_SENSOR_SERVER_HTTP_PORT=12003
I2C_SENSOR_SERVER_LOG_PATH=/var/log/mu2e-tracker-i2c-sensor-tools/i2c-sensor.log
I2C_SENSOR_SERVER_BUFFER_SIZE=256

# Shared I2C transport settings
I2C_SENSOR_SERVER_I2C_BUS=4
I2C_SENSOR_SERVER_I2C_ADDR=0x76
I2C_SENSOR_SERVER_PERIOD_S=20.0
I2C_SENSOR_SERVER_I2C_REOPEN_BACKOFF_S=1.0
I2C_SENSOR_SERVER_I2C_READ_RETRIES=2

# Optional InfluxDB sink
I2C_SENSOR_SERVER_INFLUX_URL=http://localhost:8086
I2C_SENSOR_SERVER_INFLUX_ORG=mu2e
I2C_SENSOR_SERVER_INFLUX_BUCKET=tracker-env
I2C_SENSOR_SERVER_MEASUREMENT=env_bme680
I2C_SENSOR_SERVER_INFLUX_TOKEN=

# Local no-data status tracking for the server itself
I2C_SENSOR_SERVER_NO_DATA_STREAK_TRIGGER=5
